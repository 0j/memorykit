# MemoryKit Environment Variables
# Copy this to .env and fill in your keys

# Optional: OpenAI API key for cloud embeddings + summarization
# Without this, MemoryKit uses free local models (sentence-transformers)
OPENAI_API_KEY=

# Optional: Anthropic API key for Claude-powered summarization
ANTHROPIC_API_KEY=

# Optional: Pinecone for cloud vector storage (instead of local ChromaDB)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
